# Discord Bot Token
DISCORD_TOKEN=YOUR_API_KEY

# Google Gemini API Key
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_API_KEY

# APILayer Number Verification API Key
# Get your free key at: https://apilayer.com/marketplace/number_verification-api
NUMBER_VERIFY_API_KEY=YOUR_API_KEY

# ── YouTube / yt-dlp Auth (REQUIRED for music to work in 2026) ────────────────
#
# YouTube now blocks all unauthenticated yt-dlp requests.
# You MUST supply cookies from a logged-in YouTube account.
#
# OPTION A — cookies.txt file (recommended for VPS/server hosting)
#   1. Install the "Get cookies.txt LOCALLY" extension in Chrome or Firefox
#   2. Go to https://www.youtube.com while logged in to a Google account
#   3. Click the extension icon → click "Export" → save as cookies.txt
#   4. Place cookies.txt in the same folder as bot.py
#   5. Set the path below (or just leave it as cookies.txt if in the root folder)
#
YTDLP_COOKIES_FILE=cookies.txt
#
# OPTION B — auto-read from an installed browser on the same machine
#   Set YTDLP_BROWSER to: chrome / firefox / brave / edge / chromium
#   Leave blank to disable this option.
#
YTDLP_BROWSER=
# ─────────────────────────────────────────────────────────────────────────────
